# Copy to .env and load before `python -m app.db.init_db`, or export in your shell.
# Create database `habit_tracker` first (see db/schema.sql), or let schema.sql create it.
DATABASE_URL=mysql+pymysql://root:yourpassword@127.0.0.1:3306/habit_tracker?charset=utf8mb4

# Comma-separated browser origins allowed by CORS (add your Railway frontend URL in prod).
# CORS_ORIGINS=https://your-frontend.up.railway.app

# Railway and Docker set PORT; local uvicorn defaults to 8000 if unset.
# PORT=8000
