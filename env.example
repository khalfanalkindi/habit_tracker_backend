# Copy to `.env` in this folder (gitignored). `python -m app.db.init_db` loads it automatically.
#
# SQLAlchemy needs the `mysql+pymysql://` scheme (not `mysql://`). Railway public URL example:
#   mysql://root:PASS@tramway.proxy.rlwy.net:43268/railway
# becomes:
#   DATABASE_URL=mysql+pymysql://root:PASS@tramway.proxy.rlwy.net:43268/railway?charset=utf8mb4
# URL-encode special characters in PASS (@ → %40, etc.).
#
# DB name is usually `railway` (MYSQLDATABASE). Use `init_tables.sql` / init_db against that DB.
#
# On Railway you can omit DATABASE_URL if the MySQL plugin variables are present on this service
# (MYSQLHOST, MYSQLUSER, MYSQLPASSWORD, MYSQLPORT, MYSQLDATABASE — use "Reference" from MySQL).
DATABASE_URL=mysql+pymysql://root:yourpassword@127.0.0.1:3306/railway?charset=utf8mb4

# Comma-separated browser origins allowed by CORS (add your Railway frontend URL in prod).
# CORS_ORIGINS=https://your-frontend.up.railway.app

# Railway and Docker set PORT; local uvicorn defaults to 8000 if unset.
# PORT=8000

# One shared secret: same string in Authorization: Bearer … on every /api call (set on frontend as NEXT_PUBLIC_APP_TOKEN).
# APP_TOKEN=choose-one-long-random-string

# Optional: only used when the client does not send X-User-Id. The PWA sends X-User-Id from login for /api/me/*.
# APP_USER_ID=

# Login response: browser session hint (seconds). Frontend logs out after this TTL from login time.
# SESSION_MAX_AGE_SECONDS=1209600

# Password reset: base URL for links in emails (no trailing slash), e.g. https://your-frontend.up.railway.app
# FRONTEND_PASSWORD_RESET_BASE_URL=https://your-frontend.example

# Optional SMTP — if unset, forgot-password still returns 200 but only creates a token (use admin set-password or enable dev flag).
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@example.com

# Dev only: include reset link in POST /api/auth/forgot-password JSON (never enable in production).
# PASSWORD_RESET_RETURN_LINK_IN_RESPONSE=false

# Reset token lifetime (hours).
# PASSWORD_RESET_TTL_HOURS=1
